<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">
        <Switch android:id="@+id/vibration_switch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Vibration on key press"/>
        <Switch android:id="@+id/sound_switch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sound on key press"/>
        <Switch android:id="@+id/incognito_switch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Incognito Mode"/>
    </LinearLayout>
</ScrollView>
